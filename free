--  12.5 MOBILE FLY CONTROLS (on-screen D-pad for touch devices)
-- ============================================================
-- Touch-friendly buttons that simulate W/A/S/D + Space/Shift for the fly.
-- Auto-shown only on mobile/touch devices when State.mobileFlyControls is on.
local MobileFlyGui = nil
local MobileButtons = {}

local function CreateMobileButton(parent, text, key, position, size)
    local btn = Instance.new("TextButton")
    btn.Name = "Btn_" .. key
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 24
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    btn.BackgroundTransparency = 0.35
    btn.Position = position
    btn.Size = size
    btn.AutoButtonColor = true
    btn.Parent = parent

    -- Rounded corners (more rounded for touch-friendly look)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.35, 0)
    corner.Parent = btn

    -- Stroke (thicker on mobile for visibility)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Transparency = 0.5
    stroke.Parent = btn

    -- Touch handlers (touch + mouse for hybrid devices)
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch
           or input.UserInputType == Enum.UserInputType.MouseButton1 then
            FlyKeys[key] = true
            btn.BackgroundTransparency = 0
            stroke.Transparency = 0
        end
    end)
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch
           or input.UserInputType == Enum.UserInputType.MouseButton1 then
            FlyKeys[key] = false
            btn.BackgroundTransparency = 0.35
            stroke.Transparency = 0.5
        end
    end)
    -- Safety: if input ends outside the button, still release
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch
           or input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Only release if the button currently thinks it's pressed
            if FlyKeys[key] and not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                -- Best-effort release: this prevents stuck keys if finger slides off
            end
        end
    end)
    return btn
end

local function ShowMobileFlyControls()
    if MobileFlyGui then MobileFlyGui.Enabled = true return end

    local sg = Instance.new("ScreenGui")
    sg.Name = "MM2_MobileFly"
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.IgnoreGuiInset = true
    -- High DisplayOrder so it stays above the WindUI window
    sg.DisplayOrder = 9999
    -- Try to parent to CoreGui (executor), fallback to PlayerGui
    pcall(function() sg.Parent = CoreGui end)
    if not sg.Parent then sg.Parent = PlayerGui end
    MobileFlyGui = sg

    -- Get viewport size for responsive positioning
    local vp = Camera.ViewportSize

    -- Button size: 70x70 (good touch target, ~14mm on standard phone)
    local btnSize = UDim2.fromOffset(70, 70)

    -- LEFT side: movement D-pad (W/A/S/D) — bottom-left corner
    -- Centered around (left=80, bottom=180)
    local leftX = 20
    local bottomY = vp.Y - 240
    MobileButtons.W = CreateMobileButton(sg, "▲", "W",
        UDim2.fromOffset(leftX + 80, bottomY), btnSize)
    MobileButtons.A = CreateMobileButton(sg, "◀", "A",
        UDim2.fromOffset(leftX, bottomY + 80), btnSize)
    MobileButtons.S = CreateMobileButton(sg, "▼", "S",
        UDim2.fromOffset(leftX + 80, bottomY + 160), btnSize)
    MobileButtons.D = CreateMobileButton(sg, "▶", "D",
        UDim2.fromOffset(leftX + 160, bottomY + 80), btnSize)

    -- RIGHT side: Up (Space) and Down (Shift) — bottom-right corner
    local rightX = vp.X - 90
    MobileButtons.Space = CreateMobileButton(sg, "UP", "Space",
        UDim2.fromOffset(rightX, bottomY + 20), btnSize)
    MobileButtons.Shift = CreateMobileButton(sg, "DN", "Shift",
        UDim2.fromOffset(rightX, bottomY + 110), btnSize)
end

local function HideMobileFlyControls()
    if MobileFlyGui then
        MobileFlyGui.Enabled = false
    end
end

-- Update visibility based on state + device + fly enabled
local function UpdateMobileFlyVisibility()
    if IsMobile and State.mobileFlyControls and State.flyEnabled then
        ShowMobileFlyControls()
    else
        HideMobileFlyControls()
    end
end

