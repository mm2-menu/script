-- ---------- 13.15 Coin Farm ----------
-- Robust coin finder: scans all workspace descendants for parts named coin/token/gold/event.
-- The CoinContainer path varies between maps in MM2, so we don't hardcode it.
local function GetCoins()
    local coins = {}
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local n = v.Name:lower()
            if n:find("coin") or n:find("token") or n:find("gold") or n:find("event") then
                -- Exclude things obviously not collectible (e.g. huge map parts named "GoldFloor")
                if v.Size.Magnitude < 50 then
                    table.insert(coins, v)
                end
            end
        end
    end
    return coins
end

-- Sort coins by distance to the player (nearest first)
local function SortCoinsByDistance(coins, fromPos)
    table.sort(coins, function(a, b)
        return (a.Position - fromPos).Magnitude < (b.Position - fromPos).Magnitude
    end)
end

-- Tween the player's HRP toward a coin. Uses State.coinFarmSpeed to compute travel time.
local function TweenToCoin(hrp, coin)
    if not coin or not coin.Parent then return false end
    local startPos = hrp.Position
    local targetPos = coin.Position
    local distance = (targetPos - startPos).Magnitude

    -- Travel time derived from speed (clamped between 0.2s and 2s)
    local travelTime = math.clamp(distance / math.max(State.coinFarmSpeed, 1), 0.20, 2.0)

    -- Zero out velocities to prevent physics fling
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    local targetCFrame = CFrame.new(targetPos + Vector3.new(0, 1.2, 0))
    local tween = TweenService:Create(hrp, TweenInfo.new(travelTime, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
    tween:Play()

    -- Wait for the tween to complete, aborting if the coin gets collected mid-flight
    while tween.PlaybackState == Enum.PlaybackState.Playing do
        if not coin or not coin.Parent then
            tween:Cancel()
            return false
        end
        if not State.coinFarm and not _G.CollectingOnce then
            tween:Cancel()
            return false
        end
        task.wait()
    end

    -- Reinforce with firetouchinterest if the executor supports it
    if typeof(firetouchinterest) == "function" then
        pcall(firetouchinterest, hrp, coin, 0)
        task.wait()
        pcall(firetouchinterest, hrp, coin, 1)
    end

    -- Zero velocity again to prevent fling after arrival
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    return true
end

function CollectCoinsOnce()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local coins = GetCoins()
    if #coins == 0 then
        return false
    end

    SortCoinsByDistance(coins, hrp.Position)

    if State.coinFarmMode == "Teleport" then
        -- Instant teleport mode (faster but more detectable)
        local origCFrame = hrp.CFrame
        for _, coin in ipairs(coins) do
            if not State.coinFarm and not _G.CollectingOnce then return end
            if coin and coin.Parent then
                hrp.CFrame = CFrame.new(coin.Position + Vector3.new(0, 1.2, 0))
                hrp.AssemblyLinearVelocity = Vector3.zero
                -- Reinforce touch
                if typeof(firetouchinterest) == "function" then
                    pcall(firetouchinterest, hrp, coin, 0)
                    task.wait()
                    pcall(firetouchinterest, hrp, coin, 1)
                end
                task.wait(math.random(80, 200) / 1000)
            end
        end
        hrp.CFrame = origCFrame
        return true
    end

    -- Default: Tween mode (smooth, less detectable)
    for _, coin in ipairs(coins) do
        if not State.coinFarm and not _G.CollectingOnce then return end
        if coin and coin.Parent then
            TweenToCoin(hrp, coin)
            task.wait(0.05)
        end
    end
    return true
end

function StartCoinFarm()
    task.spawn(function()
        while State.coinFarm do
            local ok, result = pcall(CollectCoinsOnce)
            if not ok then
                warn("[MM2 Hub] Coin farm error: " .. tostring(result))
            elseif result == false then
                -- No coins found, wait longer before retrying
                task.wait(2)
            else
                task.wait(0.3)
            end
        end
    end)
end

