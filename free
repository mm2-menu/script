local function SetupChatCommands()
    LocalPlayer.Chatted:Connect(function(msg)
        if not State.chatCommands then return end
        local args = string.lower(msg):split(" ")
        local cmd = args[1]
        if cmd == "/fly" then
            State.flyEnabled = not State.flyEnabled
            if State.flyEnabled then StartFly() else StopFly() end
            Notify("Chat", "Fly: " .. tostring(State.flyEnabled), 2, "solar:chat-bold")
        elseif cmd == "/noclip" then
            State.noclip = not State.noclip
            Notify("Chat", "Noclip: " .. tostring(State.noclip), 2, "solar:chat-bold")
        elseif cmd == "/esp" then
            State.espEnabled = not State.espEnabled
            if State.espEnabled then ApplyESP() else ClearESP() end
            Notify("Chat", "ESP: " .. tostring(State.espEnabled), 2, "solar:chat-bold")
        elseif cmd == "/tp" and args[2] then
            local target = Players:FindFirstChild(args[2])
            if target then
                TeleportToPlayer(target)
                Notify("Chat", "TP vers " .. args[2], 2, "solar:chat-bold")
            end
        elseif cmd == "/speed" and args[2] then
            State.walkSpeed = tonumber(args[2]) or 32
            State.speedEnabled = true
            ApplyWalkSpeed()
        elseif cmd == "/killmurderer" or cmd == "/km" then
            local m = GetMurderer()
            if m then
                TeleportToPlayer(m, 3)
                Notify("Chat", "TP vers murderer", 2, "solar:chat-bold")
            end
        elseif cmd == "/killall" then
            task.spawn(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Humanoid") then
                        local start = tick()
                        while v.Character and v.Character.Humanoid.Health > 0 and tick() - start < 5 do
                            TeleportToPlayer(v, 1)
                            task.wait(0.1)
                        end
                    end
                end
            end)
        end
    end)
end

-- ---------- 13.22 Hop Server ----------
local TeleportService = game:GetService("TeleportService")

function HopServer()
    local baseUrl = "https://games.roblox.com/v1/games/142823291/servers/Public?limit=100"
    local httpRequest = (syn and syn.request) or (http and http.request) or (request)
    if not httpRequest then
        Notify("Hop", "Your executor does not support HTTP requests", 4, "solar:warning-bold")
        return
    end
    local ok, response = pcall(function()
        return httpRequest({ Url = baseUrl, Method = "GET" })
    end)
    if not ok or not response or not response.Body then
        Notify("Hop", "Server list request failed", 4, "solar:warning-bold")
        return
    end
    local data = HttpService:JSONDecode(response.Body)
    local candidates = {}
    if data and data.data then
        for _, s in ipairs(data.data) do
            if s.playing < s.maxPlayers and s.id ~= game.JobId then
                table.insert(candidates, s)
            end
        end
    end
    if #candidates > 0 then
        local target = candidates[math.random(1, #candidates)]
        Notify("Hop", "Joining server " .. tostring(target.id):sub(1, 8) .. "...", 5, "solar:rocket-bold")
        task.wait(1)
        pcall(function()
            TeleportService:TeleportToPlaceInstance(142823291, target.id, LocalPlayer)
        end)
    else
        Notify("Hop", "No server available", 4, "solar:warning-bold")
    end
end

