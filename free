-- ---------- 13.17 Auto-Shoot Murderer ----------
function ShootMurderer()
    local m = GetMurderer()
    if not m or not m.Character then return end
    local head = m.Character:FindFirstChild("Head")
    if not head then return end
    -- Method 1: FireServer on ShootEvent (generic structure)
    local gun = nil
    if LocalPlayer.Character then
        gun = LocalPlayer.Character:FindFirstChild("Gun")
    end
    if not gun and LocalPlayer:FindFirstChild("Backpack") then
        gun = LocalPlayer.Backpack:FindFirstChild("Gun")
    end
    if not gun then
        Notify("Auto-Shoot", "You don't have a Gun (Sheriff only)", 3, "solar:warning-bold")
        return
    end
    -- Equip the Gun
    LocalPlayer.Character.Humanoid:EquipTool(gun)
    task.wait(0.1)
    -- Tenter plusieurs RemoteEvents connus
    local remotes = {
        { parent = ReplicatedStorage, name = "ShootEvent" },
        { parent = ReplicatedStorage:FindFirstChild("Events"), name = "ShootEvent" },
        { parent = gun, name = "Shoot" },
        { parent = gun, name = "Fire" },
    }
    for _, r in ipairs(remotes) do
        if r.parent and r.parent:FindFirstChild(r.name) then
            local remote = r.parent[r.name]
            if remote:IsA("RemoteEvent") then
                pcall(function()
                    remote:FireServer({
                        Origin = Camera.CFrame.Position,
                        Hit = head.CFrame,
                        Target = head,
                    }, gun)
                end)
                break
            end
        end
    end
    -- Method 2: Right click (activate tool)
    pcall(function()
        gun:Activate()
    end)
end

