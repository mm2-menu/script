-- ---------- 13.1 ESP ----------
function ClearESP()
    for p, objs in pairs(ESPObjects) do
        if objs.billboard then objs.billboard:Destroy() end
        if objs.highlight then objs.highlight:Destroy() end
        if objs.tracer then objs.tracer:Destroy() end
        if objs.box then objs.box:Destroy() end
    end
    ESPObjects = {}
end

function ApplyESP()
    ClearESP()
    if not State.espEnabled then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            CreateESPForPlayer(p)
        end
    end
end

function CreateESPForPlayer(p)
    local function build()
        local char = p.Character
        if not char then return end
        local head = char:FindFirstChild("Head")
        if not head then return end

        -- Supprimer l'ancien ESP de ce joueur
        if ESPObjects[p] then
            for _, obj in pairs(ESPObjects[p]) do
                if obj and obj.Destroy then obj:Destroy() end
            end
        end
        ESPObjects[p] = {}

        local role = GetRole(p)
        local color = RoleColor(role)

        -- Billboard pour nom + distance
        if State.espNames or State.espDistance then
            local bb = Instance.new("BillboardGui")
            bb.Name = "MM2_ESP"
            bb.Adornee = head
            bb.AlwaysOnTop = true
            bb.Size = UDim2.new(0, 200, 0, 50)
            bb.StudsOffset = Vector3.new(0, 2.5, 0)
            bb.Parent = PlayerGui

            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 14
            lbl.TextColor3 = color
            lbl.TextStrokeTransparency = 0.4
            lbl.Text = p.Name .. " [" .. role .. "]"
            lbl.Parent = bb
            ESPObjects[p].billboard = bb
            ESPObjects[p].label = lbl
        end

        -- Highlight (role color)
        local hl = Instance.new("Highlight")
        hl.Name = "MM2_HL"
        hl.Adornee = char
        hl.FillColor = color
        hl.FillTransparency = 0.5
        hl.OutlineColor = color
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = PlayerGui
        ESPObjects[p].highlight = hl

        -- Tracer (Drawing)
        if State.espTracers and Drawing then
            local tr = Drawing.new("Line")
            tr.Thickness = 1.5
            tr.Color = color
            tr.Transparency = 1
            tr.Visible = true
            ESPObjects[p].tracer = tr
        end

        -- Box (Drawing)
        if State.espBox and Drawing then
            local sq = Drawing.new("Square")
            sq.Thickness = 1.5
            sq.Color = color
            sq.Filled = false
            sq.Visible = true
            ESPObjects[p].box = sq
        end
    end

    build()
    -- Rebuild sur respawn
    p.CharacterAdded:Connect(function()
        task.wait(0.5)
        if State.espEnabled then build() end
    end)
end

-- Update ESP chaque frame
local function UpdateESP(dt)
    if not State.espEnabled then return end
    local center = Camera.ViewportSize
    local bottom = Vector2.new(center.X / 2, center.Y)

    for p, objs in pairs(ESPObjects) do
        local char = p.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not hrp or not head then continue end

        local role = GetRole(p)
        local color = RoleColor(role)

        -- Update highlight color (role may change)
        if objs.highlight then
            objs.highlight.FillColor = color
            objs.highlight.OutlineColor = color
        end

        -- Update label
        if objs.label then
            local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
            local txt = ""
            if State.espNames then txt = p.Name .. " [" .. role .. "]" end
            if State.espDistance then txt = txt .. "\n" .. dist .. " studs" end
            objs.label.Text = txt
            objs.label.TextColor3 = color
        end

        -- Update tracer
        if objs.tracer then
            local sp, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                objs.tracer.From = bottom
                objs.tracer.To = Vector2.new(sp.X, sp.Y)
                objs.tracer.Color = color
                objs.tracer.Visible = true
            else
                objs.tracer.Visible = false
            end
        end

        -- Update box
        if objs.box then
            local sp, onScreen = Camera:WorldToViewportPoint(char:GetBoundingBox().Position)
            if onScreen then
                local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
                local size = math.clamp(1000 / dist, 20, 300)
                objs.box.Size = Vector2.new(size, size * 2)
                objs.box.Position = Vector2.new(sp.X - size / 2, sp.Y - size)
                objs.box.Color = color
                objs.box.Visible = true
            else
                objs.box.Visible = false
            end
        end
    end
end

