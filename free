-- ---------- 13.6 Silent Aim (hookmetamethod) ----------
local oldNamecall, oldIndex
local function SetupSilentAim()
    if not hookmetamethod then
        Notify("Silent Aim", "hookmetamethod unavailable on this executor", 4, "solar:warning-bold")
        return
    end

    -- Hook __namecall pour rediriger les rayons
    oldNamecall = hookmetamethod(game, "__namecall", function(...)
        local args = { ... }
        local method = getnamecallmethod()
        if not checkcaller() and State.silentAim then
            local target = GetClosestPlayerToCursor(State.silentTarget)
            if target and target.Character then
                local part = target.Character:FindFirstChild(State.aimbotTarget) or target.Character:FindFirstChild("Head")
                if part then
                    if method == "Raycast" and args[1] == Workspace then
                        local origin = args[2]
                        args[3] = (part.Position - origin).Unit * 1000
                        return oldNamecall(unpack(args))
                    elseif method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRayWithWhitelist" then
                        local ray = args[2]
                        args[2] = Ray.new(ray.Origin, (part.Position - ray.Origin).Unit * 1000)
                        return oldNamecall(unpack(args))
                    end
                end
            end
        end
        return oldNamecall(...)
    end)

    -- Hook __index du Mouse pour rediriger Hit/Target
    oldIndex = hookmetamethod(game, "__index", function(t, k)
        if not checkcaller() and State.silentAim and t:IsA("Mouse") then
            local target = GetClosestPlayerToCursor(State.silentTarget)
            if target and target.Character then
                local part = target.Character:FindFirstChild(State.aimbotTarget) or target.Character:FindFirstChild("Head")
                if part then
                    if k == "Target" or k == "TargetFilter" then return part end
                    if k == "Hit" then return part.CFrame end
                    if k == "UnitRay" then
                        local origin = oldIndex(t, "Hit").Position
                        return Ray.new(origin, (part.Position - origin).Unit * 1000)
                    end
                end
            end
        end
        return oldIndex(t, k)
    end)
end

-- ---------- 13.7 Fly ----------
-- Modern CFrame-based fly. More reliable than BodyGyro/BodyVelocity.
-- We also support using the same fly system for the coin farm (with its own speed).
local FlyLoop = nil
local FlyKeyConnections = {}
local FlyKeys = { W = false, A = false, S = false, D = false, Space = false, Shift = false }

local function bindFlyKeys()
    -- Clean any previous bindings
    for _, c in ipairs(FlyKeyConnections) do
        if c and c.Disconnect then c:Disconnect() end
    end
    FlyKeyConnections = {}

    table.insert(FlyKeyConnections, UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.W then FlyKeys.W = true
        elseif input.KeyCode == Enum.KeyCode.A then FlyKeys.A = true
        elseif input.KeyCode == Enum.KeyCode.S then FlyKeys.S = true
        elseif input.KeyCode == Enum.KeyCode.D then FlyKeys.D = true
        elseif input.KeyCode == Enum.KeyCode.Space then FlyKeys.Space = true
        elseif input.KeyCode == Enum.KeyCode.LeftShift then FlyKeys.Shift = true
        end
    end))
    table.insert(FlyKeyConnections, UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.W then FlyKeys.W = false
        elseif input.KeyCode == Enum.KeyCode.A then FlyKeys.A = false
        elseif input.KeyCode == Enum.KeyCode.S then FlyKeys.S = false
        elseif input.KeyCode == Enum.KeyCode.D then FlyKeys.D = false
        elseif input.KeyCode == Enum.KeyCode.Space then FlyKeys.Space = false
        elseif input.KeyCode == Enum.KeyCode.LeftShift then FlyKeys.Shift = false
        end
    end))
end

-- Core fly logic — used both by the manual Fly toggle and the Coin Farm.
-- `speed` is the speed in studs/sec.
local function flyStep(speed)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    -- Direction based on camera
    local cam = Camera.CoordinateFrame
    local forward = cam.LookVector
    local right = cam.RightVector
    local up = Vector3.new(0, 1, 0)

    local move = Vector3.new(0, 0, 0)
    if FlyKeys.W then move = move + forward end
    if FlyKeys.S then move = move - forward end
    if FlyKeys.D then move = move + right end
    if FlyKeys.A then move = move - right end
    if FlyKeys.Space then move = move + up end
    if FlyKeys.Shift then move = move - up end

    if move.Magnitude > 0 then
        move = move.Unit * speed
    end

    -- Move the HRP directly each frame (CFrame-based — works on every executor)
    hrp.CFrame = hrp.CFrame + move * RunService.RenderStepped:Wait()
    -- Keep the character upright and facing camera direction
    hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.atan2(-forward.X, -forward.Z), 0)
    -- Disable the humanoid's own gravity handling while flying
    hum.PlatformStand = true
end

function StartFly()
    bindFlyKeys()
    if FlyLoop then FlyLoop:Disconnect() end
    local lastTime = tick()
    FlyLoop = RunService.RenderStepped:Connect(function()
        if not State.flyEnabled then
            StopFly()
            return
        end
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local hrp = char.HumanoidRootPart
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end

        local cam = Camera.CoordinateFrame
        local forward = cam.LookVector
        local right = cam.RightVector
        local up = Vector3.new(0, 1, 0)

        local move = Vector3.new(0, 0, 0)
        if FlyKeys.W then move = move + forward end
        if FlyKeys.S then move = move - forward end
        if FlyKeys.D then move = move + right end
        if FlyKeys.A then move = move - right end
        if FlyKeys.Space then move = move + up end
        if FlyKeys.Shift then move = move - up end

        if move.Magnitude > 0 then
            move = move.Unit * State.flySpeed
        end

        local now = tick()
        local dt = math.min(now - lastTime, 0.05)
        lastTime = now
        hrp.CFrame = hrp.CFrame + move * dt
        hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.atan2(-forward.X, -forward.Z), 0)
        hum.PlatformStand = true
        -- Reset velocity so the humanoid doesn't fight us
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end)
end

function StopFly()
    if FlyLoop then FlyLoop:Disconnect() end
    FlyLoop = nil
    for _, c in ipairs(FlyKeyConnections) do
        if c and c.Disconnect then c:Disconnect() end
    end
    FlyKeyConnections = {}
    local char = LocalPlayer.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        char:FindFirstChildOfClass("Humanoid").PlatformStand = false
    end
end

