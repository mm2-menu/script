-- Re-fit the UI scale on orientation / viewport changes (WindUI's AutoScale does NOT do this itself).
-- We recompute the scale manually using the same math WindUI uses internally.
local function RefitUIScale()
    if Window.IsFullscreen then return end  -- leave fullscreen alone
    local margin = 40
    local vp = Camera.ViewportSize
    local wsize = Vector2.new(
        Window.UIElements.Main.Size.X.Offset,
        Window.UIElements.Main.Size.Y.Offset
    )
    local sx = (vp.X - margin * 2) / wsize.X
    local sy = (vp.Y - margin * 2) / wsize.Y
    local s = math.clamp(math.min(sx, sy), 0.3, 1.0)
    pcall(function() Window:SetUIScale(s) end)
end

Camera:GetPropertyChangedSignal("ViewportSize"):Connect(RefitUIScale)
