-- Returns a player's role based on their inventory
local function GetRole(player)
    if not player then return "Innocent" end
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    -- Murderer = a un Knife
    if (char and char:FindFirstChild("Knife")) or (backpack and backpack:FindFirstChild("Knife")) then
        return "Murderer"
    end
    -- Sheriff / Hero = a un Gun
    if (char and char:FindFirstChild("Gun")) or (backpack and backpack:FindFirstChild("Gun")) then
        return "Sheriff"
    end
    return "Innocent"
end

-- Returns the Player object who is the murderer (or nil)
local function GetMurderer()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and GetRole(p) == "Murderer" then
            return p
        end
    end
end

-- Returns the Player object who is the sheriff (or nil)
local function GetSheriff()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and GetRole(p) == "Sheriff" then
            return p
        end
    end
end

-- Color associated with a role
local function RoleColor(role)
    if role == "Murderer" then return State.espMurdColor
    elseif role == "Sheriff" then return State.espSherColor
    else return State.espInnoColor end
end

-- Checks if a position is visible from the camera (raycast)
local function IsVisible(targetPosition)
    local origin = Camera.CFrame.Position
    local direction = (targetPosition - origin)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ignoreList = { LocalPlayer.Character }
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then table.insert(ignoreList, p.Character) end
    end
    params.FilterDescendantsInstances = ignoreList
    local result = Workspace:Raycast(origin, direction, params)
    return result == nil
end

-- Finds the closest player to the cursor within the FOV
local function GetClosestPlayerToCursor(mode)
    mode = mode or "Closest"
    local closest, shortest = nil, State.aimbotFOV
    local center = UserInputService:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local part = p.Character:FindFirstChild(State.aimbotTarget)
            if part then
                -- Filter by role if requested
                if mode == "Murderer" and GetRole(p) ~= "Murderer" then
                    -- skip
                elseif mode == "Sheriff" and GetRole(p) ~= "Sheriff" then
                    -- skip
                else
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist < shortest then
                            -- Check visibility if required
                            if State.aimbotVisibleOnly and not IsVisible(part.Position) then
                                -- skip
                            else
                                shortest = dist
                                closest = p
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- Liste des noms de joueurs (autre que LocalPlayer)
